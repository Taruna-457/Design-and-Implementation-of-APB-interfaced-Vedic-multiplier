module vedic_8x8 (
    input  [7:0] a,
    input  [7:0] b,
    output [15:0] p
);

    wire [7:0] p0, p1, p2, p3;
    wire [15:0] t0, t1, t2, t3;

    // Four 4x4 Vedic multipliers
    vedic_4x4 v0 (.a(a[3:0]), .b(b[3:0]), .p(p0));
    vedic_4x4 v1 (.a(a[7:4]), .b(b[3:0]), .p(p1));
    vedic_4x4 v2 (.a(a[3:0]), .b(b[7:4]), .p(p2));
    vedic_4x4 v3 (.a(a[7:4]), .b(b[7:4]), .p(p3));

    // Align partial products
    assign t0 = {8'b00000000, p0};
    assign t1 = {4'b0000, p1, 4'b0000};
    assign t2 = {4'b0000, p2, 4'b0000};
    assign t3 = {p3, 8'b00000000};

    // Final result
    assign p = t0 + t1 + t2 + t3;

endmodule

