module apb_vedic_multiplier (
    input  wire        PCLK,
    input  wire        PRESETn,
    input  wire        PSEL,
    input  wire        PENABLE,
    input  wire        PWRITE,
    input  wire [7:0]  PADDR,
    input  wire [31:0] PWDATA,
    output reg  [31:0] PRDATA,
    output wire        PREADY
);

    assign PREADY = 1'b1;

    reg  [15:0] A_REG, B_REG;
    wire [31:0] PRODUCT;

    vedic_16x16 u1 (
        .a(A_REG),
        .b(B_REG),
        .p(PRODUCT)
    );

    // WRITE
    always @(posedge PCLK or negedge PRESETn) begin
        if (!PRESETn) begin
            A_REG <= 0;
            B_REG <= 0;
        end else if (PSEL && PENABLE && PWRITE) begin
            case (PADDR)
                8'h00: A_REG <= PWDATA[15:0];
                8'h04: B_REG <= PWDATA[15:0];
            endcase
        end
    end

    // READ
    always @(*) begin
        if (PSEL && !PWRITE) begin
            case (PADDR)
                8'h00: PRDATA = {16'd0, A_REG};
                8'h04: PRDATA = {16'd0, B_REG};
                8'h08: PRDATA = {16'd0, PRODUCT[15:0]};
                8'h0C: PRDATA = {16'd0, PRODUCT[31:16]};
                default: PRDATA = 32'd0;
            endcase
        end else
            PRDATA = 32'd0;
    end

endmodule

`timescale 1ns/1ps

module tb_apb_vedic_multiplier;

    reg PCLK, PRESETn, PSEL, PENABLE, PWRITE;
    reg [7:0]  PADDR;
    reg [31:0] PWDATA;
    wire [31:0] PRDATA;
    wire PREADY;

    apb_vedic_multiplier dut (
        .PCLK(PCLK), .PRESETn(PRESETn), .PSEL(PSEL),
        .PENABLE(PENABLE), .PWRITE(PWRITE),
        .PADDR(PADDR), .PWDATA(PWDATA),
        .PRDATA(PRDATA), .PREADY(PREADY)
    );

    always #5 PCLK = ~PCLK;

    task apb_write(input [7:0] addr, input [31:0] data);
    begin
        @(posedge PCLK);
        PSEL=1; PWRITE=1; PADDR=addr; PWDATA=data; PENABLE=0;
        @(posedge PCLK); PENABLE=1;
        @(posedge PCLK); PSEL=0; PENABLE=0;
        $display("APB WRITE | Addr=0x%02h | Data=%0d", addr, data);
    end
    endtask

    task apb_read(input [7:0] addr);
    begin
        @(posedge PCLK);
        PSEL=1; PWRITE=0; PADDR=addr; PENABLE=0;
        @(posedge PCLK); PENABLE=1;
        @(posedge PCLK);
        $display("APB READ  | Addr=0x%02h | Data=%0d", addr, PRDATA);
        PSEL=0; PENABLE=0;
    end
    endtask

    initial begin
        PCLK=0; PRESETn=0; PSEL=0; PENABLE=0; PWRITE=0; PADDR=0; PWDATA=0;
        #10 PRESETn=1;

        // Test 1
        apb_write(8'h00,25); apb_write(8'h04,4);
        apb_read(8'h08); apb_read(8'h0C);

        // Test 2
        apb_write(8'h00,15); apb_write(8'h04,15);
        apb_read(8'h08); apb_read(8'h0C);

        // Test 3
        apb_write(8'h00,100); apb_write(8'h04,20);
        apb_read(8'h08); apb_read(8'h0C);

        // Test 4 (16-bit max)
        apb_write(8'h00,65535); apb_write(8'h04,65535);
        apb_read(8'h08); apb_read(8'h0C);

        #20 $stop;
    end

endmodule



