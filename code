module vedic_2x2 (
    input  wire [1:0] a,
    input  wire [1:0] b,
    output wire [3:0] p);
    wire p0, p1, p2, p3;
    wire carry1;
    assign p0 = a[0] & b[0];
    assign p1 = a[1] & b[0];
    assign p2 = a[0] & b[1];
    assign p3 = a[1] & b[1];
    assign p[0] = p0;
    assign p[1] = p1 ^ p2;
    assign carry1 = p1 & p2;
    assign p[2] = p3 ^ carry1;
    assign p[3] = p3 & carry1;
endmodule

module vedic_4x4 (
    input  wire [3:0] a,
    input  wire [3:0] b,
    output wire [7:0] p);
    wire [3:0] p0, p1, p2, p3;
    wire [5:0] sum1;
    wire [7:0] sum2;

    vedic_2x2 v0 (.a(a[1:0]), .b(b[1:0]), .p(p0));
    vedic_2x2 v1 (.a(a[3:2]), .b(b[1:0]), .p(p1));
    vedic_2x2 v2 (.a(a[1:0]), .b(b[3:2]), .p(p2));
    vedic_2x2 v3 (.a(a[3:2]), .b(b[3:2]), .p(p3));

    assign sum1 = p1 + p2;                 
    assign sum2 = (p3 << 4) + (sum1 << 2) + p0;
    assign p = sum2;
endmodule

